<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Jarrett Family — Today</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#111827;display:flex;align-items:center;justify-content:center;min-height:100%;padding:12px}
.fd{background:#1a1a2e;border-radius:16px;padding:16px 20px;width:100%;max-width:1400px;display:flex;flex-direction:column;gap:10px}
.fd-hdr{display:flex;justify-content:space-between;align-items:center;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,0.09)}
.fd-date-label{font-size:10px;font-weight:600;color:rgba(255,255,255,0.35);letter-spacing:2px;text-transform:uppercase;margin-bottom:2px}
.fd-date{font-size:26px;font-weight:700;color:#fff;line-height:1.1}
.fd-menu-row{display:flex;align-items:center;gap:6px;margin-top:4px}
.fd-menu-dot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.18);flex-shrink:0}
.fd-menu-text{font-size:11px;color:rgba(255,255,255,0.32);font-style:italic}
.fd-wx{display:flex;flex-direction:column;align-items:flex-end;gap:5px}
.fd-wx-today{display:flex;align-items:center;gap:7px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.11);border-radius:40px;padding:6px 14px}
.fd-wx-icon{font-size:18px;line-height:1}
.fd-wx-temp{font-size:22px;font-weight:700;color:#fff}
.fd-wx-unit{font-size:11px;color:rgba(255,255,255,0.4);align-self:flex-start;margin-top:2px;font-weight:600}
.fd-wx-week{display:flex;gap:4px}
.fd-wx-day{display:flex;flex-direction:column;align-items:center;gap:1px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.07);border-radius:7px;padding:4px 6px;min-width:34px}
.fd-wx-day .wdn{font-size:9px;color:rgba(255,255,255,0.3);font-weight:700;letter-spacing:.4px;text-transform:uppercase}
.fd-wx-day .wdi{font-size:12px;line-height:1.2}
.fd-wx-day .wdt{font-size:11px;font-weight:700;color:rgba(255,255,255,0.68)}
.fd-mid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fd-card{background:rgba(255,255,255,0.055);border:1px solid rgba(255,255,255,0.09);border-radius:12px;padding:11px 13px}
.fd-card-bright{background:#fff;border:none;border-radius:12px;padding:11px 13px}
.fd-lbl{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:7px}
.fd-lbl-dark{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(26,26,46,0.38);margin-bottom:5px}
.fd-hw-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(26,26,46,0.07)}
.fd-hw-row:last-child{border-bottom:none;padding-bottom:0}
.fd-hw-row:first-child{padding-top:0}
.fd-av{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0}
.av-m{background:#FBEAF0;color:#72243E}
.av-w{background:#FCEBEB;color:#791F1F}
.fd-hw-info{flex:1;min-width:0}
.fd-hw-sub{font-size:13px;font-weight:700;color:#1a1a2e;line-height:1.2}
.fd-hw-dsc{font-size:10px;color:rgba(26,26,46,0.42);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px}
.fd-bdg{font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;flex-shrink:0;white-space:nowrap}
.bg-soon{background:#FAEEDA;color:#633806}
.bg-now{background:#FCEBEB;color:#791F1F}
.bg-ov{background:#E24B4A;color:#fff}
.fd-task-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.07)}
.fd-task-row:last-child{border-bottom:none;padding-bottom:0}
.fd-task-row:first-child{padding-top:0}
.fd-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.dp{background:#EF9F27}.do{background:#E24B4A}.dt{background:#5DCAA5}
.fd-task-txt{font-size:13px;font-weight:600;color:#fff;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.fd-tbdg{font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;flex-shrink:0}
.tp{background:rgba(239,159,39,0.18);color:#FAC775}
.to{background:rgba(226,75,74,0.25);color:#F09595}
.tt{background:rgba(93,202,165,0.18);color:#9FE1CB}
.fd-ev-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.07)}
.fd-ev-row:last-child{border-bottom:none;padding-bottom:0}
.fd-ev-row:first-child{padding-top:0}
.fd-ev-t{min-width:50px;text-align:right;flex-shrink:0}
.fd-ev-t span{font-size:12px;font-weight:700;color:#93c5fd}
.fd-ev-t em{font-size:10px;font-style:normal;color:rgba(255,255,255,0.28)}
.fd-ev-ico{font-size:16px;flex-shrink:0;line-height:1}
.fd-ev-inf{flex:1;min-width:0}
.fd-ev-ttl{font-size:15px;font-weight:700;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fd-ev-loc{font-size:10px;color:rgba(255,255,255,0.3);margin-top:1px}
.fd-chips{display:flex;gap:3px;flex-shrink:0}
.fd-chip{font-size:10px;font-weight:600;padding:2px 6px;border-radius:20px}
.ce{background:rgba(127,119,221,0.2);color:#AFA9EC}
.ca{background:rgba(239,159,39,0.2);color:#FAC775}
.cw{background:rgba(226,75,74,0.2);color:#F09595}
.cm{background:rgba(212,83,126,0.2);color:#ED93B1}
.fd-sec{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.26);margin-bottom:5px}
.fd-wk{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none}
.fd-wk::-webkit-scrollbar{display:none}
.fd-wkc{flex-shrink:0;background:rgba(255,255,255,0.055);border:1px solid rgba(255,255,255,0.08);border-radius:9px;padding:7px 10px;min-width:108px}
.fd-wkc-d{font-size:9px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:3px}
.fd-wkc-e{font-size:11px;font-weight:600;color:rgba(255,255,255,0.78);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fd-wkc-t{font-size:10px;color:rgba(255,255,255,0.3);margin-top:1px}
.fd-wkc-n{font-size:11px;color:rgba(255,255,255,0.18);font-style:italic}
.fd-foot{display:flex;align-items:center;justify-content:space-between;padding-top:8px;border-top:1px solid rgba(255,255,255,0.07)}
.fd-foot-t{font-size:10px;color:rgba(255,255,255,0.16)}
.fd-scs{display:flex;gap:5px}
.fd-sc{width:28px;height:28px;border-radius:50%;border:1px solid rgba(255,255,255,0.09);background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;position:relative;transition:background .15s}
.fd-sc:hover{background:rgba(255,255,255,0.11)}
.fd-tip{position:absolute;bottom:33px;right:0;background:#252538;color:rgba(255,255,255,0.82);font-size:10px;font-weight:600;padding:4px 8px;border-radius:6px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;border:1px solid rgba(255,255,255,0.1)}
.fd-sc:hover .fd-tip{opacity:1}
#loading{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:16px;color:rgba(255,255,255,0.5);font-size:16px;font-weight:600}
.spinner{width:40px;height:40px;border:3px solid rgba(255,255,255,0.1);border-top-color:#3b82f6;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
#error{display:none;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:12px;padding:32px;text-align:center;color:rgba(255,255,255,0.6)}
#error h2{font-size:20px;color:#f87171}
#error p{font-size:13px;max-width:420px;line-height:1.6}
#error button{margin-top:8px;padding:9px 22px;border-radius:24px;border:1px solid #3b82f6;background:rgba(59,130,246,0.15);color:#93c5fd;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer}
#app{display:none}
</style>
</head>
<body>

<div id="loading">
  <div class="spinner"></div>
  <span>Loading today…</span>
</div>

<div id="error">
  <h2>Couldn't load</h2>
  <p id="error-msg">Set WEB_APP_URL and APP_SECRET in this file, or pass as URL params: ?url=YOUR_URL&secret=YOUR_SECRET</p>
  <button onclick="location.reload()">Try again</button>
</div>

<div id="app" style="width:100%">
  <div class="fd">

    <div class="fd-hdr">
      <div>
        <div class="fd-date-label">Jarrett family</div>
        <div class="fd-date" id="hdr-date">Today</div>
        <div class="fd-menu-row" id="menu-row" style="display:none">
          <div class="fd-menu-dot"></div>
          <div class="fd-menu-text" id="menu-text"></div>
        </div>
      </div>
      <div class="fd-wx">
        <div class="fd-wx-today">
          <span class="fd-wx-icon" id="wx-icon">–</span>
          <span class="fd-wx-temp" id="wx-temp">–</span>
          <span class="fd-wx-unit">°C</span>
        </div>
        <div class="fd-wx-week" id="wx-week"></div>
      </div>
    </div>

    <div class="fd-mid">
      <div class="fd-card-bright">
        <div class="fd-lbl-dark">Homework due next</div>
        <div id="hw-content"></div>
      </div>
      <div class="fd-card">
        <div class="fd-lbl">Things to sort</div>
        <div id="tasks-content"></div>
      </div>
    </div>

    <div class="fd-card">
      <div class="fd-sec">Today's events</div>
      <div id="events-content"></div>
    </div>

    <div>
      <div class="fd-sec">Rest of the week</div>
      <div class="fd-wk" id="week-content"></div>
    </div>

    <div class="fd-foot">
      <span class="fd-foot-t" id="footer-time">–</span>
      <div class="fd-scs">
        <div class="fd-sc" onclick="openHub()">📅<span class="fd-tip">Add event</span></div>
        <div class="fd-sc" onclick="openHub()">✅<span class="fd-tip">Add task</span></div>
        <div class="fd-sc" onclick="openHub()">📚<span class="fd-tip">Add homework</span></div>
        <div class="fd-sc" onclick="location.reload()">🔄<span class="fd-tip">Refresh</span></div>
      </div>
    </div>

  </div>
</div>

<script>
// ── CONFIG: edit these two lines, or pass as ?url=...&secret=... ──
var WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbygAOYKkq83S_yA5GCrUZkgEKdrfQc1uFRXgjrjylIHRw2-8LWUXJrSFkS_abc27Erb/exec';
var APP_SECRET  = '87311204471295316682189964520796';

(function(){
  var p=new URLSearchParams(location.search);
  if(p.get('url'))    WEB_APP_URL=p.get('url');
  if(p.get('secret')) APP_SECRET=p.get('secret');
})();

var DAYS =['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
var DAYS3=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
var MO3  =['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function todayStr(){var d=new Date();return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function isThursday(){return new Date().getDay()===4;}

function dueClass(due){
  if(!due)return'bg-soon';
  var t=new Date();t.setHours(0,0,0,0);
  var diff=Math.round((new Date(due+'T12:00:00')-t)/86400000);
  if(diff<0)return'bg-ov';
  if(diff===0)return'bg-now';
  return'bg-soon';
}
function dueLabel(due){
  if(!due)return'';
  var t=new Date();t.setHours(0,0,0,0);
  var d=new Date(due+'T12:00:00');
  var diff=Math.round((d-t)/86400000);
  if(diff<0)return'Overdue';
  if(diff===0)return'Today!';
  if(diff===1)return'Tomorrow';
  return DAYS3[d.getDay()]+' '+d.getDate()+' '+MO3[d.getMonth()];
}

function evEmoji(t){
  t=(t||'').toLowerCase();
  if(/\b(swim|swimming|pool)\b/.test(t))return'🏊';
  if(/\b(run|running|park run|jog)\b/.test(t))return'🏃';
  if(/\b(cycle|cycling|bike)\b/.test(t))return'🚴';
  if(/\b(rugby)\b/.test(t))return'🏉';
  if(/\b(football)\b/.test(t))return'⚽';
  if(/\b(tennis)\b/.test(t))return'🎾';
  if(/\b(gym|workout)\b/.test(t))return'💪';
  if(/\b(sport|match|training|practice|game|netball)\b/.test(t))return'🏆';
  if(/\b(exam|test|gcse)\b/.test(t))return'📝';
  if(/\b(school|lesson|inset|assembly|revision)\b/.test(t))return'🏫';
  if(/\b(parents.*evening|parent)\b/.test(t))return'👨‍💻';
  if(/\b(music|concert|choir|piano)\b/.test(t))return'🎵';
  if(/\b(drama|theatre|show)\b/.test(t))return'🎭';
  if(/\b(birthday)\b/.test(t))return'🎂';
  if(/\b(party|celebration)\b/.test(t))return'🎉';
  if(/\b(dinner|lunch|restaurant|meal|cafe)\b/.test(t))return'🍽️';
  if(/\b(holiday|trip|travel|flight)\b/.test(t))return'✈️';
  if(/\b(cinema|film|movie)\b/.test(t))return'🎬';
  if(/\b(doctor|dentist|hospital|appointment|physio)\b/.test(t))return'🏥';
  if(/\b(walk|hike|park|garden|dofe|duke)\b/.test(t))return'🌿';
  if(/\b(wild card|games night|film night|family meal)\b/.test(t))return'🎲';
  return'📆';
}

function chips(members){
  if(!members||!members.length)return'';
  var map={Ellen:'ce',Chris:'ce',Arthur:'ca',Wilfred:'cw',Mabel:'cm'};
  return'<div class="fd-chips">'+members.slice(0,3).map(function(m){return'<span class="fd-chip '+(map[m]||'ce')+'">'+esc(m)+'</span>';}).join('')+'</div>';
}

function renderHeader(date){
  var d=new Date(date+'T12:00:00');
  document.getElementById('hdr-date').textContent=DAYS[d.getDay()]+', '+d.getDate()+' '+MO3[d.getMonth()];
}

function renderWeather(){
  fetch('https://api.open-meteo.com/v1/forecast?latitude=51.640&longitude=-1.485&daily=weathercode,temperature_2m_max&timezone=Europe%2FLondon&temperature_unit=celsius&forecast_days=8')
    .then(function(r){return r.json();})
    .then(function(data){
      var d=data.daily;
      var ic={0:'☀️',1:'🌤',2:'⛅',3:'☁️',45:'🌫',48:'🌫',51:'🌦',55:'🌦',61:'🌧',65:'🌧',71:'🌨',77:'🌨',80:'🌦',82:'🌦',85:'🌨',86:'🌨',95:'⛈',99:'⛈'};
      function gi(c){return ic[c]||'🌥';}
      document.getElementById('wx-icon').textContent=gi(d.weathercode[0]);
      document.getElementById('wx-temp').textContent=Math.round(d.temperature_2m_max[0]);
      var h='';
      for(var i=1;i<=5;i++){var dd=new Date(d.time[i]+'T12:00:00');h+='<div class="fd-wx-day"><span class="wdn">'+DAYS3[dd.getDay()]+'</span><span class="wdi">'+gi(d.weathercode[i])+'</span><span class="wdt">'+Math.round(d.temperature_2m_max[i])+'°</span></div>';}
      document.getElementById('wx-week').innerHTML=h;
    }).catch(function(){});
}

function renderMenu(menu){
  if(isThursday()||!menu||!menu.trim())return;
  var txt=menu.replace(/^(Primary Menu|Mabel.?s (Menu|Lunch))\s*[\-\u2013]?\s*/i,'').trim();
  if(!txt)return;
  document.getElementById('menu-text').textContent='Mabel: '+txt+' — packed lunch?';
  document.getElementById('menu-row').style.display='flex';
}

function renderHomework(hw){
  var el=document.getElementById('hw-content');
  function row(name,cls,data){
    if(!data)return'';
    return'<div class="fd-hw-row"><div class="fd-av '+cls+'">'+esc(name.charAt(0))+'</div><div class="fd-hw-info"><div class="fd-hw-sub">'+esc(data.subject||'Homework')+'</div>'+(data.desc?'<div class="fd-hw-dsc">'+esc(data.desc)+'</div>':'')+'</div>'+(dueLabel(data.due)?'<div class="fd-bdg '+dueClass(data.due)+'">'+esc(dueLabel(data.due))+'</div>':'')+'</div>';
  }
  var h=row('Mabel','av-m',hw&&hw.mabel)+row('Wilfred','av-w',hw&&hw.wilfred);
  el.innerHTML=h||'<div style="font-size:12px;color:rgba(26,26,46,0.32);font-style:italic;padding:4px 0">All clear!</div>';
}

function renderTasks(tasks){
  var el=document.getElementById('tasks-content');
  var today=todayStr();
  var pri=(tasks||[]).filter(function(t){return t.priority;});
  var ov=(tasks||[]).filter(function(t){return t.overdue&&!t.priority;});
  var td=(tasks||[]).filter(function(t){return!t.priority&&!t.overdue&&t.due===today;});
  var all=pri.concat(ov).concat(td);
  if(!all.length){el.innerHTML='<div style="font-size:12px;color:rgba(255,255,255,0.22);font-style:italic;padding:4px 0">All clear!</div>';return;}
  el.innerHTML=all.map(function(t){
    var dc=t.priority?'dp':t.overdue?'do':'dt';
    var bc=t.priority?'tp':t.overdue?'to':'tt';
    var bl=t.priority?'Priority':t.overdue?'Overdue':'Due today';
    return'<div class="fd-task-row"><div class="fd-dot '+dc+'"></div><div class="fd-task-txt">'+esc(t.title||'')+'</div><div class="fd-tbdg '+bc+'">'+bl+'</div></div>';
  }).join('');
}

function renderEvents(events,today){
  var el=document.getElementById('events-content');
  var todays=(events||[]).filter(function(e){return e.date===today;});
  todays.sort(function(a,b){if(a.time==='All day'&&b.time!=='All day')return 1;if(b.time==='All day'&&a.time!=='All day')return-1;return(a.time||'')<(b.time||'')?-1:1;});
  if(!todays.length){el.innerHTML='<div style="font-size:12px;color:rgba(255,255,255,0.22);font-style:italic;padding:4px 0">Nothing on today</div>';return;}
  el.innerHTML=todays.map(function(ev){
    var isAD=!ev.time||ev.time==='All day';
    return'<div class="fd-ev-row"><div class="fd-ev-t">'+(isAD?'<em>all day</em>':'<span>'+esc(ev.time)+'</span>')+'</div><div class="fd-ev-ico">'+evEmoji(ev.title)+'</div><div class="fd-ev-inf"><div class="fd-ev-ttl">'+esc(ev.title)+'</div>'+(ev.loc?'<div class="fd-ev-loc">'+esc(ev.loc)+'</div>':'')+'</div>'+chips(ev.members)+'</div>';
  }).join('');
}

function renderWeek(events,today){
  var el=document.getElementById('week-content');
  var html='';
  for(var i=1;i<=6;i++){
    var d=new Date();d.setDate(d.getDate()+i);
    var ds=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
    var evs=(events||[]).filter(function(e){return e.date===ds;});
    evs.sort(function(a,b){return(a.time||'')<(b.time||'')?-1:1;});
    html+='<div class="fd-wkc"><div class="fd-wkc-d">'+DAYS3[d.getDay()]+' '+d.getDate()+'</div>';
    if(!evs.length){html+='<div class="fd-wkc-n">Nothing on</div>';}
    else{evs.slice(0,2).forEach(function(ev){var ht=ev.time&&ev.time!=='All day';html+='<div class="fd-wkc-e">'+evEmoji(ev.title)+' '+esc(ev.title)+'</div>'+(ht?'<div class="fd-wkc-t">'+esc(ev.time)+'</div>':'');});if(evs.length>2)html+='<div class="fd-wkc-t">+'+(evs.length-2)+' more</div>';}
    html+='</div>';
  }
  el.innerHTML=html;
}

function openHub(){if(WEB_APP_URL)window.open(WEB_APP_URL,'_blank');}

function load(){
  if(!WEB_APP_URL||!APP_SECRET){
    document.getElementById('loading').style.display='none';
    document.getElementById('error').style.display='flex';
    return;
  }
  fetch(WEB_APP_URL+'?secret='+encodeURIComponent(APP_SECRET))
    .then(function(r){if(!r.ok)throw new Error('HTTP '+r.status);return r.json();})
    .then(function(data){
      if(data.error)throw new Error(data.error);
      var today=data.date||todayStr();
      renderHeader(today);
      renderWeather();
      renderMenu(data.menu);
      renderHomework(data.homework);
      renderTasks(data.tasks);
      renderEvents(data.events,today);
      renderWeek(data.events,today);
      var now=new Date();
      document.getElementById('footer-time').textContent='Updated '+now.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'})+' · auto-refreshes every 10 mins';
      document.getElementById('loading').style.display='none';
      document.getElementById('app').style.display='block';
    })
    .catch(function(err){
      document.getElementById('loading').style.display='none';
      document.getElementById('error').style.display='flex';
      document.getElementById('error-msg').textContent='Error: '+err.message;
    });
}

setInterval(function(){location.reload();},10*60*1000);
load();
</script>
</body>
</html>
